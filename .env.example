PORT=3000
MONGODB_URI=mongodb://localhost:27017/sipanda

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

SEED_ADMIN_NAMA=Super Admin
SEED_ADMIN_EMAIL=admin@sipanda.local
SEED_ADMIN_PASSWORD=ChangeMe123!

FACE_SERVICE_BASE_URL=http://localhost:4001/api
FACE_SERVICE_WEBHOOK_SECRET=change-me-webhook-secret
# Must match (or be <= ) face-service's own FACE_MATCH_THRESHOLD — face-service
# already gates matches against its threshold+margin before returning a
# student_id, so this backend-side threshold decides auto-confirm (Hadir) vs
# needing manual guru verification. If this is set higher than what the
# calibrated model can realistically produce (see face-service/.env comments),
# every match falls through to manual verification even when correctly
# identified.
FACE_MATCH_THRESHOLD=0.4

# Kosongkan SMTP_HOST untuk mode dev (email hanya dicatat di log, tidak benar-benar terkirim)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SIPANDA <noreply@sipanda.local>
